# EstreGenesis × Codex — MCP server declarations (example).
# Generated by codex/gen-codex-adapter.cjs --write. Do NOT hand-edit; edit the
# generator or the source plugin manifests instead (a verify-nway axis gates drift).
#
# Replace __EG_REPO_ROOT__ with the absolute path to your EstreGenesis checkout,
# then paste the stanzas you want into ~/.codex/config.toml (global) or a trusted
# project's .codex/config.toml. Servers with a dependency need `npm install` in their
# mcp/ directory first (see codex/README.md).

[mcp_servers.compendium]
command = "node"
args = ["__EG_REPO_ROOT__/plugins/compendium/mcp/server.cjs"]
startup_timeout_sec = 15
  # deps-0

[mcp_servers.constellation]
command = "node"
args = ["__EG_REPO_ROOT__/plugins/constellation/mcp/server.cjs"]
startup_timeout_sec = 15
  # requires: npm install (ws) in plugins/constellation/mcp/

[mcp_servers.hyperbrief]
command = "node"
args = ["__EG_REPO_ROOT__/plugins/hyperbrief/mcp/server.cjs"]
startup_timeout_sec = 15
  # requires: npm install (ajv) in plugins/hyperbrief/mcp/

[mcp_servers.ultrasafe]
command = "node"
args = ["__EG_REPO_ROOT__/plugins/ultrasafe/mcp/server.cjs"]
startup_timeout_sec = 15
  # requires: npm install (ajv) in plugins/ultrasafe/mcp/

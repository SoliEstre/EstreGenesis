/assets/
.claude/settings.local.json

# Constellation reference runtime — single-instance lockfile (per _proposals/003 Fix 1, local-bridge.cjs L53)
# Per-agentId PID lockfile written by the single-instance guard; never tracked.
constellation/reference/runtime/.*-bridge.lock

# Constellation reference runtime — operational JSONL streams (inbox / outbox / etc.)
# Written by the running runtime when it acts as the local bridge for an interactive
# session. Reference impl source (*.cjs, *.sh, *.md) stays tracked; these jsonl
# operational artifacts do not. Memory feedback_workspace_cleanliness applies.
constellation/reference/runtime/*.jsonl

# Local agent-workspace artifacts at repo root (bootstrap policy).
# Public reference docs and the constellation/ tree stay tracked; agent-local rule sheets / config / scratch dirs do not.
/AGENTS.md
/.agent/
/.agent-*
/agents.json

# Agent-local scratch directory — one-off helper scripts the agent writes when
# orchestrating multi-turn work (outbox push helpers, bundle decode scripts,
# probe wrappers, etc). Ephemeral and project-local; never tracked.
# Memory feedback_workspace_cleanliness applies.
/tmp/
